        expand("results/tools/bcftools/{condition}_{sample}.bcf", condition=config["conditions"], sample=config["samples"]),
        "results/tools/jacusa2/Jacusa.out",
        # Downstream analysis is handled separately (see downstream.smk).
        # Run `snakemake results/downstream/multiple_analysis.done` to execute it
        # after patching the Benchmark scripts for this environment.